# Database — use either DATABASE_URL or POSTGRES_* (Supabase Session Pooler)
# Session Pooler (port 5432) is recommended for persistent Docker containers.
# Get the exact host from: Supabase Dashboard → Connect → Session pooler
# DATABASE_URL=postgresql://postgres.xxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
POSTGRES_HOST=aws-0-eu-central-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxx
POSTGRES_PASSWORD=your_password

# Supabase Auth (login)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server
PORT=80

# Optional: Redis for shared cache (otherwise in-memory)
# REDIS_URL=redis://default:password@host:6379

# Required for the scheduled jobs in vercel.json (recompute opportunities,
# mine message timelines, regenerate stale AI personas, send the daily
# digest). Vercel automatically sends this as a Bearer token on cron-
# triggered requests once it's set here — generate any random string.
# CRON_SECRET=

# Telegram bot (daily digest + input bot). Create a bot via @BotFather to
# get the token. Without these, the bot routes stay inert (503/401) and
# nothing else in the app is affected.
# TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to log notes via the input bot
# (DM @userinfobot to find your own ID). Empty/unset = no one is authorized.
# TELEGRAM_ADMIN_IDS=
# Chat ID the daily digest gets sent to (a group or your own DM chat ID).
# TELEGRAM_DIGEST_CHAT_ID=
# Optional but recommended: set this to any random string, then pass the
# same value as `secret_token` when calling Telegram's setWebhook so the
# webhook route can verify requests actually come from Telegram.
# TELEGRAM_WEBHOOK_SECRET=
